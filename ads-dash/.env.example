# Supabase — copie este arquivo para .env e preencha com suas credenciais
# Acesse: https://supabase.com/dashboard → seu projeto → Settings → API

VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Fonte de dados: "mock" (default) usa localStorage; "supabase" usa as tabelas remotas.
VITE_DATA_SOURCE=mock

# [DEPRECATED em 2026-07-10] O login estático (VITE_DEV_LOGIN_* + VITE_ALLOW_STATIC_LOGIN)
# foi removido. O app agora exige sessão Supabase Auth real. Criar as contas via
# Supabase Dashboard → Authentication → Users.

# Chave compartilhada com Edge Functions (frontend envia em x-internal-key)
# Mesmo valor precisa estar configurado em Supabase → Edge Functions → Secrets como INTERNAL_API_KEY
VITE_INTERNAL_API_KEY=

# Variáveis abaixo são SECRETS da Edge Function (configurar em Supabase → Edge Functions → Secrets, NÃO no .env do front)
# INTERNAL_API_KEY=mesmo_valor_do_VITE_INTERNAL_API_KEY
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM=The Blonde Concept <relatorios@seudominio.com>
# IG_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx
# IG_BUSINESS_ACCOUNT_ID=17841401234567890
# WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxx               (WhatsApp Cloud API — token permanente)
# WHATSAPP_PHONE_NUMBER_ID=1234567890             (ID do número no Meta Business)
